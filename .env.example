# Environment
NODE_ENV=development

# Server Ports
PORT=3000
METRICS_PORT=9463

# Database Configuration
DB_HOST=localhost
DB_PORT=3309
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=lxp_code_review

# Redis Queue Configuration
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=
REDIS_QUEUE_DB=0

# Queue Settings
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000

# Codex CLI Configuration
CODEX_BINARY_PATH=codex
CODEX_TIMEOUT_MS=600000
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=high

# Bitbucket Configuration
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_API_TOKEN=your_api_token
# (deprecated) App Password 방식 - API Token이 없을 때 fallback으로 사용
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WEBHOOK_SECRET=

# Workspace Configuration
WORKSPACE_BASE_PATH=/tmp/code-review-workspaces
WORKSPACE_MAX_CONCURRENT=3

# Review Trigger Mode (mention | auto | both)
REVIEW_TRIGGER_MODE=mention

# Logging
LOG_LEVEL=info

# TypeORM Configuration
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Database Connection Pool
DB_POOL_SIZE=5
DB_POOL_MAX_IDLE=2

# OpenTelemetry Configuration (optional)
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SERVICE_VERSION=1.0.0
